# Optional — get a free token at https://huggingface.co/settings/tokens
# Without it: keyword-based topic tagging still works, but Personalize and
# Content Angles features require a token.
HF_TOKEN=

# Optional — create at https://github.com/settings/tokens (no scopes needed)
# Without it: GitHub API is limited to 60 req/hr (shared across Trending +
# Releases); with it: 5000 req/hr. Rate-limit errors are handled gracefully.
GITHUB_TOKEN=

# Daily email digest (sent at 10:00 AM local time, or on-demand via the dashboard)
# DIGEST_EMAIL_TO: recipient address
# DIGEST_EMAIL_FROM: the Gmail address you send from
# GMAIL_APP_PASSWORD: NOT your Gmail password — create an App Password at
#   myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
DIGEST_EMAIL_TO=
DIGEST_EMAIL_FROM=
GMAIL_APP_PASSWORD=
